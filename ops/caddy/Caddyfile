{
	# Cloudflare handles TLS at the edge; Caddy only speaks HTTP on :80.
	auto_https off
	# Don't expose the admin API.
	admin off

	servers {
		# Trust private ranges as proxies so the CF-Connecting-IP header
		# from cloudflared is accepted as the real client IP.
		trusted_proxies static private_ranges
		client_ip_headers CF-Connecting-IP X-Forwarded-For
	}

	log default {
		output stdout
		format json
		level INFO
	}
}

(security) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=()"
		-Server
	}
}

api-{$PUBLIC_HOST_SUFFIX}:80 {
	import security
	reverse_proxy bff:8082
}

admin-api-{$PUBLIC_HOST_SUFFIX}:80 {
	import security
	reverse_proxy adminapi:8088
}

admin-{$PUBLIC_HOST_SUFFIX}:80 {
	import security
	reverse_proxy dashboard:3000
}

grafana-{$PUBLIC_HOST_SUFFIX}:80 {
	import security
	reverse_proxy grafana:3000
}

metabase-{$PUBLIC_HOST_SUFFIX}:80 {
	import security
	reverse_proxy metabase:3000
}

# Any unmatched Host header → 404 (guards against hostname typos
# and direct-IP probes if the network were ever misconfigured).
:80 {
	respond "not found" 404 {
		close
	}
}
