{
  "title": "OfflinePay — Overview",
  "uid": "offlinepay-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "method",
        "type": "query",
        "label": "RPC method",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(offlinepay_grpc_requests_total, method)",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "RPC request rate (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (method) (rate(offlinepay_grpc_requests_total{method=~\"$method\"}[1m]))",
          "legendFormat": "{{method}}"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "id": 2,
      "title": "RPC errors / 5m",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (code) (rate(offlinepay_grpc_requests_total{code!=\"OK\"}[5m]))",
          "legendFormat": "{{code}}"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },
    {
      "id": 3,
      "title": "RPC latency (p95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, method) (rate(offlinepay_grpc_request_duration_seconds_bucket{method=~\"$method\"}[5m])))",
          "legendFormat": "p95 {{method}}"
        }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 }
    },
    {
      "id": 4,
      "title": "Settlement latency by phase (p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, phase) (rate(offlinepay_settlement_latency_seconds_bucket[5m])))",
          "legendFormat": "p99 {{phase}}"
        }
      ],
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 }
    },
    {
      "id": 5,
      "title": "Active ceilings",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "offlinepay_ceiling_active_total" }
      ],
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 6 }
    },
    {
      "id": 6,
      "title": "Lien age at release (p50/p95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(offlinepay_lien_age_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(offlinepay_lien_age_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ],
      "gridPos": { "x": 6, "y": 16, "w": 12, "h": 6 }
    },
    {
      "id": 7,
      "title": "Fraud signals / min by type",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (type) (rate(offlinepay_fraud_signal_total[1m])) * 60",
          "legendFormat": "{{type}}"
        }
      ],
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 }
    },
    {
      "id": 8,
      "title": "Gossip uploads / min",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(offlinepay_gossip_upload_total[1m]) * 60", "legendFormat": "uploads/min" }
      ],
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 }
    }
  ]
}
