{
  "title": "OfflinePay — Transfers",
  "uid": "offlinepay-transfers",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Outbox pending count",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "offlinepay_outbox_pending_count",
          "legendFormat": "pending"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "id": 2,
      "title": "Outbox oldest age (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "offlinepay_outbox_oldest_age_seconds",
          "legendFormat": "oldest age"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },
    {
      "id": 3,
      "title": "Transfer dispatch rate (/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(offlinepay_outbox_dispatched_total[1m])",
          "legendFormat": "dispatched/s"
        },
        {
          "expr": "rate(offlinepay_outbox_dispatch_failures_total[1m])",
          "legendFormat": "failures/s"
        }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 }
    },
    {
      "id": 4,
      "title": "Transfer outcomes (/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (status) (rate(offlinepay_transfer_processed_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ],
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 }
    }
  ]
}
