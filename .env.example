# ---------------------------------------------------------------------
# OfflinePay — example environment
#
# Copy to `.env` and fill in the secrets. `docker-compose.yml` uses its
# own hardcoded values; this file is for running binaries directly on
# the host (go run ./cmd/bff, ./cmd/adminapi, ./cmd/transferworker, …).
# ---------------------------------------------------------------------

# ---------- Common ---------------------------------------------------
OFFLINEPAY_ENV=local
OFFLINEPAY_LOG_LEVEL=info
OFFLINEPAY_LOG_FORMAT=

DB_URL=postgres://offlinepay:offlinepay@localhost:5432/offlinepay?sslmode=disable
REDIS_URL=redis://localhost:6379/0
NATS_URL=nats://localhost:4222

# Run embedded migrations at boot. Safe for dev; disable in prod when a
# dedicated migrate step is part of the deploy pipeline.
MIGRATE_ON_BOOT=true

# Offline-wallet lifecycle timers.
CEILING_TTL_HOURS=24
AUTO_SETTLE_TIMEOUT_HOURS=72
CLOCK_GRACE_MINUTES=30

# Sealed-box keypair for gossip-blob decryption. 32-byte X25519 privkey,
# hex-encoded. PREVIOUS_PRIVKEYS is a comma-separated list used for
# rotation (decrypt-only).
SERVER_SEALED_BOX_PRIVKEY=
SERVER_SEALED_BOX_PREVIOUS_PRIVKEYS=

# Crypto signer: "local" | "vault".
CRYPTO_SIGNER=local
VAULT_ADDR=
VAULT_TOKEN=
VAULT_TRANSIT_MOUNT=transit

# Device attestation: "dev" | "production".
ATTESTATION_MODE=dev

# ---------- BFF (cmd/bff) --------------------------------------------
BFF_HTTP_ADDR=:8082

# HMAC secret for user access tokens; must be >= 32 bytes in production.
BFF_JWT_SECRET=
BFF_JWT_AUDIENCE=offlinepay-user
BFF_ACCESS_TTL_MINUTES=15
BFF_REFRESH_TTL_HOURS=168
BFF_OTP_TTL_MINUTES=5
BFF_OTP_MAX_ATTEMPTS=5

# Per-user rate limiter (requests per second and burst capacity).
BFF_RATE_LIMIT_RPS=20
BFF_RATE_LIMIT_BURST=40

# Dev-only surfaces. Default ON outside production; force ON here to
# enable when OFFLINEPAY_ENV=production (do not do this in real prod).
BFF_ENABLE_DEV_TOPUP=true
BFF_ENABLE_DEMO_MINT=true

# ---------- Admin API (cmd/adminapi, backoffice REST) ----------------
ADMIN_HTTP_ADDR=:8081
ADMIN_CORS_ORIGIN=http://localhost:3000
ADMIN_JWT_SECRET=
ADMIN_JWT_AUDIENCE=offlinepay-admin
ADMIN_ACCESS_TTL_MINUTES=15
ADMIN_REFRESH_TTL_HOURS=168

# ---------- Transfer worker (cmd/transferworker) ---------------------
WORKER_BATCH_SIZE=16
WORKER_DISPATCH_INTERVAL_MS=500
WORKER_METRICS_ADDR=:9102

# ---------- FCM push (cmd/transferworker) ----------------------------
# Only the transferworker dispatches push notifications — leave blank to
# skip FCM entirely; the worker falls back to the LogSender stub and
# boots normally. Download the service-account JSON from the Firebase
# console (Project settings → Service accounts → Generate new private
# key). The JSON loader accepts three forms in this order:
#   1. raw JSON (starts with `{`)
#   2. base64-encoded JSON (for compose / k8s secrets)
#   3. filesystem path
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=

# ---------- Observability --------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_SERVICE_NAME=offlinepay-bff
OTEL_SERVICE_VERSION=0.1.0
# Sampling ratio 0.0–1.0. Empty → 1.0 in dev, 0.1 in production.
OTEL_TRACES_SAMPLER_RATIO=
